{
  "name": "@flashlogs/sdk",
  "version": "1.0.0",
  "description": "The lightweight, high-performance logging SDK for Flash Logs. Real-time structured logging, automatic metadata capture, and sub-millisecond ingestion for Next.js, Express, and Node.js.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/frameworks/next.d.ts",
      "import": "./dist/frameworks/next.js",
      "require": "./dist/frameworks/next.cjs"
    },
    "./express": {
      "types": "./dist/frameworks/express.d.ts",
      "import": "./dist/frameworks/express.js",
      "require": "./dist/frameworks/express.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/frameworks/next.ts src/frameworks/express.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "logs",
    "flashlogs-kolektive",
    "structured-logging",
    "observability",
    "audit",
    "monitoring",
    "security",
    "nextjs",
    "express",
    "flashlogs"
  ],
  "author": "Flashlogs Kolektive",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+ https://github.com/Flashlogs-Kolektive/flashlogs-next.git"
  },
  "bugs": {
    "url": "https://github.com/Flashlogs-Kolektive/flashlogs-next/issues"
  },
  "homepage": "https://flashlogs.co.za/docs/nextjs",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "react": "^19.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
